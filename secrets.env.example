# Secrets and configuration for aiwilli services.
# Install as ${XDG_CONFIG_HOME:-$HOME/.config}/wballenthin/weave/secrets.env
# Used by: direnv (.envrc), systemd (weave.service)
IMAP_HOST=imap.example.com
IMAP_USER=you@example.com
IMAP_PASSWORD=your-app-password
WEAVE_BASE_EMAIL=you@example.com
WEAVE_ALLOWED_SENDERS=you@gmail.com,my@remarkable.com
WEAVE_VAULT_ROOT=/path/to/obsidian-vault
# optional
WEAVE_AGENT_SESSIONS_DIR=/path/to/agent-sessions
# for mprocs
COLUMNS=80
